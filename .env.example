# Copy to .env and fill in your values.

# PostgreSQL connection string (e.g. from Neon, Vercel Postgres, or Supabase).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Secret used to sign login sessions (JWT). Use a long random string.
JWT_SECRET="change-me-to-a-long-random-string"

NODE_ENV="development"

# --- LLM provider (optional — powers AI guide generation + content audit) ---
# Leave blank to disable the AI features.
OPENROUTER_API_KEY=""   # https://openrouter.ai/keys  (keys start "sk-or-")
GROQ_API_KEY=""         # https://console.groq.com    (keys start "gsk_")

# --- Seeding (used by `npm run seed`) ---
# SEED_ADMIN_PASSWORD="your-strong-admin-password"
# SEED_DEMO="false"     # set to false to seed ONLY the admin (no demo accounts)
