# Copy to .env and fill in your values.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/mindcob_content?schema=public"
JWT_SECRET="change-me-to-a-long-random-string"
NODE_ENV="development"

# --- LLM provider (guide generation + AI content audit) ---
# Pick either; the app prefers OpenRouter when both are set. OpenRouter uses
# your own credits (no tight rate limits); Groq is fast/free but throttled.
OPENROUTER_API_KEY=""   # https://openrouter.ai/keys  (keys start with sk-or-)
GROQ_API_KEY=""         # https://console.groq.com     (keys start with gsk_)
# Optional: force a provider / model.
# LLM_PROVIDER="openrouter"
# LLM_MODEL="openai/gpt-4o-mini"
